{
  "name": "wow-admin",
  "version": "2.4.2",
  "description": "Desktop admin tool for AzerothCore servers with SOAP and Database editing",
  "main": "dist/main.js",
  "scripts": {
    "build:ts": "node esbuild.config.js",
    "build:ts:watch": "node esbuild.config.js --watch",
    "build:css": "tailwindcss -i ./renderer/styles/tailwind.css -o ./renderer/styles/output.css",
    "build:css:watch": "tailwindcss -i ./renderer/styles/tailwind.css -o ./renderer/styles/output.css --watch",
    "extract:maps": "node scripts/extract-map-assets.mjs",
    "start": "npm run build:ts && npm run build:css && electron . --no-sandbox",
    "dev": "npm run build:ts && npm run build:css && electron . --dev --no-sandbox",
    "build": "npm run build:ts && npm run build:css && node scripts/package.js",
    "build:win": "npm run build:ts && npm run build:css && node scripts/package.js --win",
    "build:mac": "npm run build:ts && npm run build:css && node scripts/package.js --mac",
    "build:linux": "npm run build:ts && npm run build:css && node scripts/package.js --linux",
    "build:all": "npm run build:ts && npm run build:css && node scripts/package.js --win --linux",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "azerothcore",
    "wow",
    "soap",
    "admin",
    "azerothcore-tools",
    "database-editor"
  ],
  "author": "scarecr0w12 <scarecr0w12@users.noreply.github.com>",
  "homepage": "https://github.com/scarecr0w12/wowmin",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/xml2js": "^0.4.14",
    "autoprefixer": "^10.4.16",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.19.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@types/ssh2": "^1.15.5",
    "jpeg-js": "^0.4.4",
    "js-blp": "^1.0.5",
    "mysql2": "^3.6.0",
    "pngjs": "^7.0.0",
    "ssh2": "^1.17.0",
    "stormlib-js": "^0.1.1",
    "xml2js": "^0.6.2"
  },
  "build": {
    "appId": "com.wowadmin.azerothcore",
    "productName": "WoW Admin",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/*.js",
      "dist/*.js.map",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-${version}-setup-win-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-setup-win-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-win-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon_1024.png",
      "category": "public.app-category.utilities",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Utility",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    }
  }
}
